      "type": "single",
      "required": true,
      "options": [
        { "id": "mostly-correct", "label": "It is usually correct when it sounds confident", "fluencyScore": 0, "technicalScore": 0 },
        { "id": "some-errors", "label": "It can make mistakes, so I should check important outputs", "fluencyScore": 1.5, "technicalScore": 0.5 },
        { "id": "context-limits", "label": "It has context, recency, bias, and source limitations", "fluencyScore": 2.5, "technicalScore": 1.5 },
        { "id": "risk-aware", "label": "I account for limitations when designing or reviewing AI-assisted work", "fluencyScore": 3, "technicalScore": 2 }
      ]
    },
    {
      "id": "technicalExperience",
      "title": "Which technical background best describes you?",
      "type": "single",
      "required": true,
      "options": [
        { "id": "general", "label": "I use standard office or productivity tools", "fluencyScore": 0.5, "technicalScore": 0 },
        { "id": "low-code", "label": "I use templates, formulas, automations, or low-code tools", "fluencyScore": 1, "technicalScore": 1 },
        { "id": "developer-data", "label": "I work with code, data, analytics, APIs, or scripts", "fluencyScore": 1.5, "technicalScore": 2 },
        { "id": "ai-builder", "label": "I build, adapt, evaluate, or govern AI/ML systems", "fluencyScore": 2, "technicalScore": 3 }
      ]
    },
    {
      "id": "aiResponsibilities",
      "title": "Which AI-related responsibilities apply to you?",
      "type": "multiple",
      "required": true,
      "options": [
        { "id": "individual-user", "label": "I mainly use AI for my own work", "fluencyScore": 0.5, "technicalScore": 0 },
        { "id": "reviewer", "label": "I review AI-assisted work before it is used", "fluencyScore": 1.5, "technicalScore": 0.5 },
        { "id": "supervisor", "label": "I supervise or approve AI-assisted work", "fluencyScore": 2, "technicalScore": 1 },
        { "id": "governance", "label": "I help set policy, governance, or review practices", "fluencyScore": 2.5, "technicalScore": 1.5 },
        { "id": "builder", "label": "I build or configure AI-assisted workflows or systems", "fluencyScore": 2.5, "technicalScore": 2.5 }
      ]
    }
