{
  "assessmentVersion": "phase-2-joint-force-v2",
  "profileThresholds": {
    "practicalFluency": [
      { "maxScore": 0.74, "levelId": "new-to-ai" },
      { "maxScore": 1.59, "levelId": "foundational-user" },
      { "maxScore": 2.49, "levelId": "applied-user" },
      { "maxScore": 3, "levelId": "advanced-practitioner" }
    ],
    "technicalOrientation": [
      { "maxScore": 0.74, "levelId": "general-user" },
      { "maxScore": 1.74, "levelId": "productivity-low-code" },
      { "maxScore": 2.59, "levelId": "developer-data-practitioner" },
      { "maxScore": 3, "levelId": "ai-ml-builder" }
    ]
  },
  "scoring": {
    "scaleMaximum": 3,
    "practicalFluency": {
      "weights": {
        "demonstratedPracticalExperience": 0.25,
        "promptWorkflowSkill": 0.2,
        "verificationBehavior": 0.2,
        "responsibleUseJudgment": 0.2,
        "limitationsUnderstanding": 0.1,
        "useFrequency": 0.05
      },
      "gates": {
        "noIndependentActivitiesMaxLevel": "foundational-user",
        "appliedRequiresFlag": "independentPracticalUse",
        "advancedRequiresFlags": ["repeatableWorkflow"],
        "advancedMinimumSignals": {
          "verificationBehavior": 3,
          "responsibleUseJudgment": 3,
          "promptWorkflowSkill": 2.4
        },
        "advancedFallbackLevel": "applied-user"
      }
    },
    "technicalOrientation": {
      "weights": {
        "technicalExperience": 0.75,
        "technicalActivity": 0.25
      },
      "gates": {
        "developerRequiresFlag": "developerDataEvidence",
        "developerFallbackLevel": "productivity-low-code",
        "aiMlRequiresFlag": "aiMlBuilderEvidence",
        "aiMlFallbackLevel": "developer-data-practitioner"
      }
    }
  },
  "questions": [
    {
      "id": "genAiFrequency",
      "title": "How often have you used a generative-AI tool during the past 30 days?",
      "type": "single",
      "required": true,
      "options": [
        {
          "id": "never",
          "label": "Never",
          "scoringSignals": { "useFrequency": 0 }
        },
        {
          "id": "once-or-twice",
          "label": "Once or twice",
          "scoringSignals": { "useFrequency": 0.6 }
        },
        {
          "id": "several-times",
          "label": "Several times",
          "scoringSignals": { "useFrequency": 1.2 }
        },
        {
          "id": "weekly",
          "label": "Weekly",
          "scoringSignals": { "useFrequency": 1.8 }
        },
        {
          "id": "several-times-week",
          "label": "Several times per week",
          "scoringSignals": { "useFrequency": 2.4 }
        },
        {
          "id": "daily",
          "label": "Daily",
          "scoringSignals": { "useFrequency": 3 }
        }
      ]
    },
    {
      "id": "independentExperience",
      "title": "Which of the following have you done independently?",
      "type": "multiple",
      "required": true,
      "mutuallyExclusiveOptionId": "none-yet",
      "options": [
        {
          "id": "none-yet",
          "label": "None yet",
          "scoringSignals": { "demonstratedPracticalExperience": 0, "technicalActivity": 0 },
          "evidenceFlags": ["noIndependentActivities"]
        },
        {
          "id": "simple-question",
          "label": "Asked an AI tool a simple question",
          "scoringSignals": { "demonstratedPracticalExperience": 0.7 },
          "evidenceFlags": ["independentPracticalUse"]
        },
        {
          "id": "revised-prompt",
          "label": "Revised a prompt after receiving a poor result",
          "scoringSignals": { "demonstratedPracticalExperience": 1.4, "promptWorkflowSkill": 1.4 },
          "evidenceFlags": ["independentPracticalUse", "promptRevision"]
        },
        {
          "id": "provided-context",
          "label": "Supplied context, examples, or source material",
          "scoringSignals": { "demonstratedPracticalExperience": 1.8, "promptWorkflowSkill": 2 },
          "evidenceFlags": ["independentPracticalUse", "promptRevision"]
        },
        {
          "id": "verified-authoritative",
          "label": "Compared AI output against authoritative sources",
          "scoringSignals": { "demonstratedPracticalExperience": 2, "verificationBehavior": 2.5 },
          "evidenceFlags": ["independentPracticalUse", "verificationPractice"]
        },
        {
          "id": "reusable-template",
          "label": "Created a reusable prompt or template",
          "scoringSignals": { "demonstratedPracticalExperience": 2.2, "promptWorkflowSkill": 2.2 },
          "evidenceFlags": ["independentPracticalUse", "promptRevision"]
        },
        {
          "id": "repeatable-workflow",
          "label": "Used AI as one step in a repeatable workflow",
          "scoringSignals": { "demonstratedPracticalExperience": 3, "promptWorkflowSkill": 2.5 },
          "evidenceFlags": ["independentPracticalUse", "repeatableWorkflow"]
        },
        {
          "id": "code-data-api-automation",
          "label": "Used an AI API, coding assistant, or automation tool",
          "scoringSignals": { "demonstratedPracticalExperience": 1.8, "technicalActivity": 2.6 },
          "evidenceFlags": ["independentPracticalUse", "developerDataEvidence"]
        },
        {
          "id": "ai-ml-system",
          "label": "Built or evaluated an AI or machine-learning system",
          "scoringSignals": { "demonstratedPracticalExperience": 2, "technicalActivity": 3 },
          "evidenceFlags": ["independentPracticalUse", "developerDataEvidence", "aiMlBuilderEvidence"]
        }
      ]
    },
    {
      "id": "verifyOutput",
      "title": "An AI system produces a convincing answer for an important work product. What would you normally do?",
      "type": "single",
      "required": true,
      "options": [
        {
          "id": "use-appears-reasonable",
          "label": "Use it because it appears reasonable",
          "scoringSignals": { "verificationBehavior": 0 }
        },
        {
          "id": "read-obvious-errors",
          "label": "Read it for obvious errors",
          "scoringSignals": { "verificationBehavior": 1 }
        },
        {
          "id": "verify-important-claims",
          "label": "Independently verify important claims against authoritative sources",
          "scoringSignals": { "verificationBehavior": 2.4 }
        },
        {
          "id": "verify-document-judgment",
          "label": "Verify claims, inspect available sources, document uncertainty, and determine what requires human judgment",
          "scoringSignals": { "verificationBehavior": 3, "limitationsUnderstanding": 2.5 }
        }
      ]
    },
    {
      "id": "promptWorkflow",
      "title": "An AI response is incomplete or inaccurate. What are you most likely to do next?",
      "type": "single",
      "required": true,
      "options": [
        {
          "id": "stop-using",
          "label": "Stop using the tool",
          "scoringSignals": { "promptWorkflowSkill": 0 }
        },
        {
          "id": "ask-same-again",
          "label": "Ask the same question again",
          "scoringSignals": { "promptWorkflowSkill": 0.5 }
        },
        {
          "id": "rewrite-more-detail",
          "label": "Rewrite the question with more detail",
          "scoringSignals": { "promptWorkflowSkill": 1.5 }
        },
        {
          "id": "add-context-format",
          "label": "Add context, constraints, examples, and a requested output format",
          "scoringSignals": { "promptWorkflowSkill": 2.4 }
        },
        {
          "id": "break-test-steps",
          "label": "Break the task into smaller steps and test each step separately",
          "scoringSignals": { "promptWorkflowSkill": 3 },
          "evidenceFlags": ["repeatableWorkflow"]
        }
      ]
    },
    {
      "id": "responsibleHandling",
      "title": "Before entering work-related information into an AI system, which best describes your approach?",
      "type": "single",
      "required": true,
      "reminder": "Do not provide actual sensitive examples when answering.",
      "options": [
        {
          "id": "enter-needed",
          "label": "I generally enter whatever information is needed",
          "scoringSignals": { "responsibleUseJudgment": 0 }
        },
        {
          "id": "avoid-obvious-sensitive",
          "label": "I avoid obviously personal or sensitive information",
          "scoringSignals": { "responsibleUseJudgment": 1 }
        },
        {
          "id": "approved-minimize",
          "label": "I determine whether the tool is approved and minimize the information entered",
          "scoringSignals": { "responsibleUseJudgment": 2.4 }
        },
        {
          "id": "full-handling-review",
          "label": "I consider tool approval, classification or sensitivity, retention, access, downstream use, and required human review",
          "scoringSignals": { "responsibleUseJudgment": 3, "verificationBehavior": 2 }
        }
      ]
    },
    {
      "id": "limitations",
      "title": "A teammate says a generative-AI answer must be reliable because it is detailed and confident. Which response best matches your understanding?",
      "type": "single",
      "required": true,
      "options": [
        {
          "id": "confidence-reliable",
          "label": "Confidence and detail usually mean the answer is reliable",
          "scoringSignals": { "limitationsUnderstanding": 0 }
        },
        {
          "id": "sometimes-wrong",
          "label": "It can sometimes be wrong, so I would check the most important facts",
          "scoringSignals": { "limitationsUnderstanding": 1.5, "verificationBehavior": 1 }
        },
        {
          "id": "patterns-bias-context",
          "label": "It generates outputs from learned patterns and can be plausible but incorrect, incomplete, or biased",
          "scoringSignals": { "limitationsUnderstanding": 2.4, "verificationBehavior": 1.8 }
        },
        {
          "id": "task-consequence-review",
          "label": "I would account for those limitations and verify output based on the task, sources, context, bias risk, and consequences",
          "scoringSignals": { "limitationsUnderstanding": 3, "verificationBehavior": 2.7 }
        }
      ]
    },
    {
      "id": "technicalExperience",
      "title": "Which best describes your technical experience?",
      "type": "single",
      "required": true,
      "options": [
        {
          "id": "ordinary-software",
          "label": "I primarily use ordinary workplace software",
          "scoringSignals": { "technicalExperience": 0 }
        },
        {
          "id": "advanced-spreadsheets-low-code",
          "label": "I use advanced spreadsheets, formulas, or low-code tools",
          "scoringSignals": { "technicalExperience": 1.5 },
          "evidenceFlags": ["lowCodeEvidence"]
        },
        {
          "id": "scripts-query-data",
          "label": "I write scripts or query data",
          "scoringSignals": { "technicalExperience": 2.2 },
          "evidenceFlags": ["developerDataEvidence"]
        },
        {
          "id": "software-apis",
          "label": "I develop software or use APIs",
          "scoringSignals": { "technicalExperience": 2.6 },
          "evidenceFlags": ["developerDataEvidence"]
        },
        {
          "id": "ai-ml-builder",
          "label": "I build, train, deploy, or evaluate AI or machine-learning systems",
          "scoringSignals": { "technicalExperience": 3 },
          "evidenceFlags": ["developerDataEvidence", "aiMlBuilderEvidence"]
        }
      ]
    },
    {
      "id": "aiResponsibility",
      "title": "Which best describes your relationship to AI-assisted work?",
      "type": "single",
      "required": true,
      "options": [
        {
          "id": "own-tasks",
          "label": "I primarily complete my own tasks",
          "scoringSignals": { "responsibilityAuthority": 0 }
        },
        {
          "id": "review-others",
          "label": "I review other people's work",
          "scoringSignals": { "responsibilityAuthority": 1.5 }
        },
        {
          "id": "supervise-approve",
          "label": "I supervise personnel or approve products",
          "scoringSignals": { "responsibilityAuthority": 2.2 }
        },
        {
          "id": "policy-risk",
          "label": "I develop policy or manage organizational risk",
          "scoringSignals": { "responsibilityAuthority": 3 }
        },
        {
          "id": "build-operate-systems",
          "label": "I build or operate technical systems",
          "scoringSignals": { "responsibilityAuthority": 2.4 },
          "evidenceFlags": ["technicalResponsibility"]
        }
      ]
    }
  ],
  "learningGoals": [
    { "id": "ai-terminology-capabilities", "label": "Understand AI terminology and capabilities" },
    { "id": "generative-ai-productivity", "label": "Use generative AI for everyday productivity" },
    { "id": "research-analysis", "label": "Improve research and analysis" },
    { "id": "writing-communication", "label": "Improve writing and communication" },
    { "id": "work-with-data", "label": "Work with data" },
