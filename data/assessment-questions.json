      "id": "genAiFrequency",
      "title": "How often have you used generative AI tools recently?",
      "type": "single",
      "required": true,
      "options": [
        { "id": "never", "label": "I have not used them yet", "fluencyScore": 0, "technicalScore": 0 },
        { "id": "tried-once", "label": "I have tried them once or twice", "fluencyScore": 0.5, "technicalScore": 0 },
        { "id": "monthly", "label": "A few times a month", "fluencyScore": 1, "technicalScore": 0.5 },
        { "id": "weekly", "label": "At least weekly", "fluencyScore": 2, "technicalScore": 1 },
        { "id": "daily", "label": "Most workdays", "fluencyScore": 3, "technicalScore": 1.5 }
      ]
    },
    {
      "id": "completedActivities",
      "title": "Which AI-assisted activities have you completed independently?",
      "type": "multiple",
      "required": true,
      "options": [
        { "id": "none-yet", "label": "None yet", "fluencyScore": 0, "technicalScore": 0 },
        { "id": "drafted-content", "label": "Drafted or revised written content", "fluencyScore": 1, "technicalScore": 0.5 },
        { "id": "summarized-info", "label": "Summarized information and checked the result", "fluencyScore": 1.5, "technicalScore": 0.5 },
        { "id": "prompt-iteration", "label": "Improved prompts through multiple iterations", "fluencyScore": 2, "technicalScore": 1 },
        { "id": "workflow-support", "label": "Used AI inside a repeatable workflow", "fluencyScore": 2.5, "technicalScore": 1.5 },
        { "id": "code-data", "label": "Used AI for code, data, or automation work", "fluencyScore": 2.5, "technicalScore": 2.5 },
        { "id": "evaluated-system", "label": "Evaluated or configured an AI-enabled tool", "fluencyScore": 3, "technicalScore": 3 }
      ]
    },
    {
      "id": "verifyOutput",
      "title": "If an AI answer sounds plausible but important, what would you do?",
      "type": "single",
      "required": true,
      "options": [
        { "id": "accept", "label": "Use it if it sounds confident", "fluencyScore": 0, "technicalScore": 0 },
        { "id": "quick-check", "label": "Do a quick reasonableness check", "fluencyScore": 1, "technicalScore": 0.5 },
        { "id": "source-check", "label": "Check it against trusted sources or source material", "fluencyScore": 2, "technicalScore": 1 },
        { "id": "structured-review", "label": "Use a structured review before acting on it", "fluencyScore": 3, "technicalScore": 1.5 }
      ]
    },
    {
      "id": "promptBreakdown",
