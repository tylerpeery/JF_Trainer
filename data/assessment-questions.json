  "learningGoals": [
    "Understand AI basics",
    "Use AI responsibly",
    "Evaluate AI outputs",
    "Improve prompting and task breakdown",
    "Apply AI to my role",
    "Build or automate workflows",
    "Govern or supervise AI-assisted work"
  ],
  "weeklyTimeOptions": [
    { "id": "under-1", "label": "Less than 1 hour per week" },
    { "id": "1-2", "label": "1 to 2 hours per week" },
