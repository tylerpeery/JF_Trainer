    { "id": "supervise-ai-work", "label": "Supervise AI-assisted work" },
    { "id": "build-ai-apps", "label": "Build AI-enabled applications" },
    { "id": "understand-machine-learning", "label": "Understand machine learning" },
    { "id": "teach-others", "label": "Teach others to use AI" }
  ],
  "weeklyTimeOptions": [
    { "id": "under-30", "label": "Less than 30 minutes" },
    { "id": "30-60", "label": "30 to 60 minutes" },
    { "id": "1-2", "label": "1 to 2 hours" },
