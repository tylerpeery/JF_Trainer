        { "id": "stop", "label": "Stop using the tool for that task", "fluencyScore": 0, "technicalScore": 0 },
        { "id": "retry-simple", "label": "Ask the same thing in a simpler way", "fluencyScore": 1, "technicalScore": 0.5 },
        { "id": "add-context", "label": "Add context, constraints, or examples", "fluencyScore": 2, "technicalScore": 1 },
        { "id": "break-down", "label": "Break the task into smaller steps and evaluate each one", "fluencyScore": 3, "technicalScore": 1.5 }
      ]
    },
    {
      "id": "responsibleHandling",
      "title": "How would you handle work information in a public AI tool?",
      "type": "single",
      "required": true,
      "options": [
        { "id": "paste-needed", "label": "Paste whatever is needed to get the best answer", "fluencyScore": 0, "technicalScore": 0 },
        { "id": "remove-obvious", "label": "Remove obvious names and identifiers first", "fluencyScore": 1, "technicalScore": 0.5 },
        { "id": "use-fictional", "label": "Use fictional or generalized information whenever possible", "fluencyScore": 2, "technicalScore": 1 },
        { "id": "follow-policy", "label": "Follow approved tools, policies, and data-handling rules", "fluencyScore": 3, "technicalScore": 1.5 }
      ]
    },
    {
